<footer>
  <div class="container">
    <div class="footer-grid">
      <div>
        <p style="font-family:var(--font-display);font-size:1.3rem;font-weight:900;color:var(--sand);margin-bottom:.5rem;">
          <span style="color:var(--clay)">R</span>APP
        </p>
        <p style="font-size:.88rem;line-height:1.8;max-width:280px; color:rgba(245,239,230,.8);">
          Rwandans Allied for Peace and Progress — building bridges, empowering communities, and advancing sustainable development across Rwanda.
        </p>
        <div style="display:flex;gap:.75rem;margin-top:1.25rem;">
          <a href="#" aria-label="Facebook" class="social-icon">f</a>
          <a href="#" aria-label="Twitter" class="social-icon">𝕏</a>
          <a href="#" aria-label="LinkedIn" class="social-icon">in</a>
          <a href="#" aria-label="YouTube" class="social-icon">▶</a>
        </div>
      </div>
      <div>
        <h4>Navigation</h4>
        <ul class="footer-list">
          <li><a href="/">Home</a></li>
          <li><a href="/projects">Projects</a></li>
          <li><a href="/partners">Partners</a></li>
          <li><a href="/about">About Us</a></li>
          <li><a href="/contact">Contact Us</a></li>
        </ul>
      </div>
      <div>
        <h4>Get Involved</h4>
        <ul class="footer-list">
          <li><a href="/donate">Donate Now</a></li>
          <li><a href="/volunteer">Volunteer</a></li>
          <li><a href="/partners">Partnership</a></li>
          <li><a href="/blog">Blog</a></li>
        </ul>
      </div>
      <div>
        <h4>Contact</h4>
        <ul class="footer-list" style="gap:.6rem">
          <li>📍 Kigali, Rwanda</li>
          <li>✉️ info@rapp.rw</li>
          <li>📞 +250 700 000 000</li>
        </ul>
      </div>
    </div>
    <div class="footer-bottom">
      <span>© {new Date().getFullYear()} RAPP — Rwandans Allied for Peace & Progress. All rights reserved.</span>
      <span>Made with ❤️ for Rwanda</span>
    </div>
  </div>
</footer>

<style>
.footer-list {
  list-style: none;
  display: flex;
  flex-direction: column;
  gap: .45rem;
  font-size: .88rem;
}
.footer-list a { transition: color .2s; }
.footer-list a:hover { color: var(--gold); }
.social-icon {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 36px; height: 36px;
  border-radius: 50%;
  border: 1px solid rgba(245,239,230,.2);
  font-size: .85rem;
  font-weight: 700;
  color: rgba(245,239,230,.7);
  transition: all .2s;
}
.social-icon:hover {
  border-color: var(--gold);
  color: var(--gold);
  transform: translateY(-2px);
}
</style>
