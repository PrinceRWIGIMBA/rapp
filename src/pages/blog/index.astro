---
import Base from '../../layouts/Base.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import allPostsData from '../../data/posts.json';
const allPosts = allPostsData.items;

const tagColors: Record<string, string> = {
  Projects: '#3B82F6',
  Events: '#10B981',
  Partnerships: '#2E8B7A',
  Environment: '#6B8F71',
  Women: '#8B5CF6',
  Health: '#EF4444',
};

const posts = allPosts;
const tags = ['All', ...Array.from(new Set(posts.map((p: any) => p.tag)))];
---

<Base title="Blog" description="News, stories, and updates from RAPP — Rwandans Allied for Peace and Progress.">
  <Nav />

  <div class="page-hero" style="background-image: url('https://images.unsplash.com/photo-1499750310107-5fef28a66643?w=1400&q=80')">
    <div class="container">
      <span class="section-label fade-up">Stories & Updates</span>
      <h1 class="fade-up-2">RAPP Blog</h1>
      <p class="fade-up-3">News, impact stories, and insights from our work across Rwanda.</p>
    </div>
  </div>

  <section class="section">
    <div class="container">
      <!-- Tags -->
      <div class="tags-bar">
        {tags.map(t => (
          <button class={`tag-btn ${t === 'All' ? 'active' : ''}`}>{t}</button>
        ))}
      </div>

      <!-- Featured -->
      <article class="featured-post card">
        <div class="featured-img-wrap">
          <img src={posts[0].img} alt={posts[0].title} class="featured-img" />
          <span class="post-tag">{posts[0].tag}</span>
        </div>
        <div class="featured-body">
          <div class="post-meta">
            <time>{posts[0].date}</time>
            <span>·</span>
            <span>{posts[0].readTime}</span>
            <span>·</span>
            <span>By {posts[0].author}</span>
          </div>
          <h2 class="featured-title">{posts[0].title}</h2>
          <p class="featured-excerpt">{posts[0].excerpt}</p>
          <a href={`/blog/${posts[0].slug}`} class="btn btn-primary" style="margin-top:1.5rem;">Read Full Story</a>
        </div>
      </article>

      <!-- Grid -->
      <div class="posts-grid">
        {posts.slice(1).map(p => (
          <article class="card post-card">
            <div class="post-img-wrap">
              <img src={p.img} alt={p.title} class="post-img" />
              <span class="post-tag">{p.tag}</span>
            </div>
            <div class="post-body">
              <div class="post-meta">
                <time>{p.date}</time>
                <span>·</span>
                <span>{p.readTime}</span>
              </div>
              <h3 class="post-title">{p.title}</h3>
              <p class="post-excerpt">{p.excerpt}</p>
              <div style="display:flex;justify-content:space-between;align-items:center;margin-top:1rem;">
                <span style="font-size:.8rem;color:var(--muted);">By {p.author}</span>
                <a href={`/blog/${p.slug}`} class="post-link">Read More →</a>
              </div>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- Newsletter -->
  <section class="section bg-sand">
    <div class="container newsletter-wrap">
      <div class="newsletter-box">
        <div>
          <span class="section-label">Stay Updated</span>
          <h2 style="font-size:1.75rem;">Subscribe to Our Newsletter</h2>
          <p style="margin-top:.5rem;max-width:400px;">Get the latest news and impact stories from RAPP delivered to your inbox monthly.</p>
        </div>
        <div class="newsletter-form">
          <input type="email" placeholder="your@email.com" />
          <button class="btn btn-primary">Subscribe</button>
        </div>
      </div>
    </div>
  </section>

  <Footer />
</Base>

<style>
.tags-bar {
  display: flex;
  gap: .5rem;
  flex-wrap: wrap;
  margin-bottom: 2.5rem;
}
.tag-btn {
  padding: .4rem 1.1rem;
  border-radius: 999px;
  border: 1.5px solid rgba(59,42,26,.2);
  background: transparent;
  font-family: var(--font-body);
  font-size: .85rem;
  font-weight: 500;
  cursor: pointer;
  transition: all .2s;
  color: var(--earth);
}
.tag-btn:hover, .tag-btn.active {
  background: var(--clay);
  color: #fff;
  border-color: var(--clay);
}

.featured-post {
  display: grid;
  grid-template-columns: 1fr 1fr;
  margin-bottom: 3rem;
  min-height: 420px;
}
.featured-img-wrap { position: relative; overflow: hidden; }
.featured-img { width: 100%; height: 100%; object-fit: cover; min-height: 320px; }
.post-tag {
  position: absolute;
  top: 1rem; left: 1rem;
  background: var(--clay);
  color: #fff;
  font-size: .7rem;
  font-weight: 700;
  letter-spacing: .08em;
  text-transform: uppercase;
  padding: .3rem .75rem;
  border-radius: 999px;
}
.featured-body {
  padding: 3rem 2.5rem;
  display: flex;
  flex-direction: column;
  justify-content: center;
}
.post-meta {
  display: flex;
  gap: .5rem;
  align-items: center;
  font-size: .8rem;
  color: var(--muted);
  margin-bottom: .75rem;
  flex-wrap: wrap;
}
.featured-title { font-size: 1.75rem; margin-bottom: 1rem; }
.featured-excerpt { font-size: .95rem; }

.posts-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1.75rem;
}
.post-img-wrap { position: relative; height: 210px; overflow: hidden; }
.post-img { width: 100%; height: 100%; object-fit: cover; transition: transform .5s var(--ease); }
.post-card:hover .post-img { transform: scale(1.06); }
.post-body { padding: 1.4rem; }
.post-title { font-size: 1.05rem; margin: .5rem 0 .6rem; line-height: 1.4; }
.post-excerpt { font-size: .87rem; }
.post-link { font-weight: 600; font-size: .87rem; color: var(--clay); }
.post-link:hover { text-decoration: underline; }

/* Newsletter */
.newsletter-wrap { max-width: 900px; margin: 0 auto; }
.newsletter-box {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 2rem;
  flex-wrap: wrap;
}
.newsletter-form { display: flex; gap: .75rem; flex-wrap: wrap; }
.newsletter-form input {
  padding: .75rem 1.25rem;
  border: 1.5px solid rgba(59,42,26,.2);
  border-radius: var(--r);
  font-family: var(--font-body);
  font-size: .95rem;
  min-width: 240px;
  outline: none;
  transition: border-color .2s;
  background: #fff;
}
.newsletter-form input:focus { border-color: var(--clay); }

@media (max-width: 900px) {
  .featured-post { grid-template-columns: 1fr; }
  .posts-grid    { grid-template-columns: repeat(2, 1fr); }
}
@media (max-width: 600px) {
  .posts-grid { grid-template-columns: 1fr; }
  .newsletter-form input { min-width: 100%; }
}
</style>
