---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import partnersData from '../data/partners.json';

const { hero, tiers, howToPartner } = partnersData;
---

<Base title="Partners" description="Meet the organizations partnering with RAPP to build peace and progress in Rwanda.">
  <Nav />

  <div class="page-hero" style={`background-image: url('${hero.image}')`}>
    <div class="container">
      <span class="section-label fade-up">{hero.label}</span>
      <h1 class="fade-up-2">{hero.title}</h1>
      <p class="fade-up-3">{hero.subtitle}</p>
    </div>
  </div>

  <!-- Partner tiers -->
  <section class="section">
    <div class="container">
      {tiers.map(tier => (
        <div class="tier-section">
          <div class="tier-header">
            <span class="tier-line" style={`background:${tier.color}`}></span>
            <h2 class="tier-title">{tier.level}</h2>
          </div>
          <div class="partners-grid">
            {tier.partners.map(p => (
              <div class="partner-card">
                <div class="partner-logo" style={`border-color:${tier.color}`}>
                  {p.name.split(' ').slice(0,2).map(w => w[0]).join('')}
                </div>
                <div class="partner-info">
                  <span class="partner-type">{p.type}</span>
                  <h3 class="partner-name">{p.name}</h3>
                  <p class="partner-desc">{p.desc}</p>
                </div>
              </div>
            ))}
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- How to Partner -->
  <section class="section bg-sand">
    <div class="container">
      <div class="section-header" style="text-align:center;">
        <span class="section-label">Join Our Network</span>
        <h2>Become a Partner</h2>
        <div class="divider" style="margin:1rem auto;"></div>
        <p style="max-width:520px;margin:0 auto;">
          We welcome partners who are committed to sustainable peace and development. Here's how you can collaborate with RAPP.
        </p>
      </div>
      <div class="how-grid">
        {howToPartner.map(h => (
          <div class="how-card">
            <div class="how-icon">{h.icon}</div>
            <h3>{h.title}</h3>
            <p>{h.desc}</p>
          </div>
        ))}
      </div>
      <div style="text-align:center;margin-top:3rem;">
        <a href="/contact" class="btn btn-primary">Start a Conversation</a>
      </div>
    </div>
  </section>

  <!-- Testimonial -->
  <section class="section">
    <div class="container">
      <div class="testimonial-block">
        <div class="quote-mark">"</div>
        <blockquote>
          Working with RAPP has been one of the most impactful partnerships we've experienced in East Africa. Their deep community roots and passionate team deliver results that transform lives.
        </blockquote>
        <cite>— Senior Programme Officer, UNDP Rwanda</cite>
      </div>
    </div>
  </section>

  <Footer />
</Base>

<style>
.tier-section { margin-bottom: 4rem; }
.tier-header {
  display: flex;
  align-items: center;
  gap: 1rem;
  margin-bottom: 2rem;
}
.tier-line {
  width: 4px;
  height: 2rem;
  border-radius: 2px;
  flex-shrink: 0;
}
.tier-title { font-size: 1.5rem; }

.partners-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 1.25rem;
}
.partner-card {
  display: flex;
  gap: 1rem;
  align-items: flex-start;
  background: #fff;
  padding: 1.25rem;
  border-radius: calc(var(--r)*2);
  box-shadow: 0 2px 12px rgba(59,42,26,.06);
  transition: transform .3s var(--ease), box-shadow .3s;
}
.partner-card:hover {
  transform: translateY(-4px);
  box-shadow: 0 12px 40px rgba(59,42,26,.12);
}
.partner-logo {
  flex-shrink: 0;
  width: 52px; height: 52px;
  border-radius: 12px;
  border: 2px solid;
  display: flex;
  align-items: center;
  justify-content: center;
  font-family: var(--font-display);
  font-weight: 900;
  font-size: 1.1rem;
  color: var(--earth);
  background: var(--sand);
}
.partner-type {
  font-size: .72rem;
  font-weight: 600;
  letter-spacing: .1em;
  text-transform: uppercase;
  color: var(--clay);
}
.partner-name { font-size: .95rem; margin: .25rem 0 .35rem; }
.partner-desc { font-size: .82rem; }

.how-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 1.5rem;
  margin-top: 3rem;
}
.how-card {
  background: #fff;
  padding: 2rem 1.5rem;
  border-radius: calc(var(--r)*2);
  box-shadow: 0 2px 12px rgba(59,42,26,.06);
  text-align: center;
  transition: transform .3s;
}
.how-card:hover { transform: translateY(-6px); }
.how-icon { font-size: 2.5rem; margin-bottom: 1rem; }
.how-card h3 { font-size: 1rem; margin-bottom: .5rem; }
.how-card p  { font-size: .88rem; }

.testimonial-block {
  max-width: 720px;
  margin: 0 auto;
  text-align: center;
  position: relative;
  padding: 3rem;
  background: var(--sand);
  border-radius: calc(var(--r)*3);
}
.quote-mark {
  font-family: var(--font-display);
  font-size: 8rem;
  line-height: 1;
  color: var(--clay);
  opacity: .15;
  position: absolute;
  top: -.5rem; left: 1.5rem;
}
blockquote {
  font-family: var(--font-display);
  font-style: italic;
  font-size: 1.3rem;
  line-height: 1.65;
  color: var(--night);
  position: relative;
  z-index: 1;
}
cite {
  display: block;
  margin-top: 1.5rem;
  font-size: .88rem;
  font-style: normal;
  color: var(--muted);
}

@media (max-width: 1024px) {
  .partners-grid { grid-template-columns: repeat(2, 1fr); }
  .how-grid       { grid-template-columns: repeat(2, 1fr); }
}
@media (max-width: 600px) {
  .partners-grid { grid-template-columns: 1fr; }
  .how-grid       { grid-template-columns: 1fr; }
}
</style>
