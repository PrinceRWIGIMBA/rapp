---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import partnersData from '../data/partners.json';

const { hero, tiers, howToPartner } = partnersData;

const typeIconMap: Record<string, string> = {
  NGO:           'building-community',
  Finance:       'coin',
  International: 'world',
  Government:    'building',
  Academia:      'school',
  'Think Tank':  'bulb',
};
---

<Base title="Partners" description="Meet the organisations partnering with RAPP to build peace and progress in Rwanda.">
  <Nav />

  <div class="page-hero" style={`background-image: url('${hero.image}')`}>
    <div class="container">
      <span class="section-label fade-up">{hero.label}</span>
      <h1 class="fade-up-2">{hero.title}</h1>
      <p class="fade-up-3">{hero.subtitle}</p>
    </div>
  </div>

  <!-- Partner tiers -->
  <section class="section">
    <div class="container">
      {tiers.map(tier => (
        <div class="tier-section">
          <div class="tier-header">
            <span class="tier-pill">{tier.level}</span>
          </div>
          <div class="partners-grid">
            {tier.partners.map(p => {
              const initials = p.name.split(' ').slice(0, 2).map((w: string) => w[0]).join('');
              const icon = typeIconMap[p.type] ?? 'building';
              return (
                <div class="partner-card">
                  <div class="card-top">
                    <div class="partner-avatar">{initials}</div>
                    <div class="partner-meta">
                      <span class="partner-badge">
                        <i class={`ti ti-${icon}`} aria-hidden="true"></i>
                        {p.type}
                      </span>
                      <h3 class="partner-name">{p.name}</h3>
                    </div>
                  </div>
                  <div class="card-divider"></div>
                  <p class="partner-desc">{p.desc}</p>
                </div>
              );
            })}
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- How to Partner -->
  <section class="section bg-sand">
    <div class="container">
      <div class="section-header" style="text-align:center;">
        <span class="section-label">Join Our Network</span>
        <h2>Become a Partner</h2>
        <div class="divider" style="margin:1rem auto;"></div>
        <p style="max-width:520px;margin:0 auto;">
          We welcome partners who are committed to sustainable peace and development. Here's how you can collaborate with RAPP.
        </p>
      </div>
      <div class="how-grid">
        {howToPartner.map(h => (
          <div class="how-card">
            <div class="how-icon">{h.icon}</div>
            <h3>{h.title}</h3>
            <p>{h.desc}</p>
          </div>
        ))}
      </div>
      <div style="text-align:center;margin-top:3rem;">
        <a href="/contact" class="btn btn-primary">Start a Conversation</a>
      </div>
    </div>
  </section>

  <!-- Testimonial -->
  <section class="section">
    <div class="container">
      <div class="testimonial-block">
        <div class="quote-mark">"</div>
        <blockquote>
          Working with RAPP has been one of the most impactful partnerships we've experienced in East Africa. Their deep community roots and passionate team deliver results that transform lives.
        </blockquote>
        <cite>— Senior Programme Officer, UNDP Rwanda</cite>
      </div>
    </div>
  </section>

  <Footer />
</Base>

<style>
/* ── Tier header ── */
.tier-section   { margin-bottom: 4rem; }
.tier-header    { margin-bottom: 2.5rem; }
.tier-pill {
  display: inline-block;
  font-size: .75rem;
  font-weight: 600;
  letter-spacing: .08em;
  text-transform: uppercase;
  color: var(--teal);
  background: color-mix(in srgb, var(--teal) 10%, transparent);
  padding: .35rem 1rem;
  border-radius: 2rem;
  border: 1px solid color-mix(in srgb, var(--teal) 25%, transparent);
}

/* ── Partners grid ── */
.partners-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1.25rem;
}

/* ── Individual card ── */
.partner-card {
  background: #fff;
  border: 1px solid rgba(59,42,26,.08);
  border-radius: 16px;
  padding: 1.5rem;
  display: flex;
  flex-direction: column;
  gap: 1rem;
  transition: border-color .25s ease, box-shadow .25s ease, transform .25s ease;
}
.partner-card:hover {
  border-color: rgba(59,42,26,.16);
  box-shadow: 0 8px 32px rgba(59,42,26,.08);
  transform: translateY(-3px);
}

.card-top {
  display: flex;
  align-items: flex-start;
  gap: 1rem;
}

/* Avatar circle */
.partner-avatar {
  flex-shrink: 0;
  width: 48px;
  height: 48px;
  border-radius: 12px;
  background: color-mix(in srgb, var(--teal) 10%, transparent);
  border: 2px solid var(--teal);
  outline: 4px solid color-mix(in srgb, var(--teal) 15%, transparent);
  display: flex;
  align-items: center;
  justify-content: center;
  font-family: var(--font-display);
  font-weight: 700;
  font-size: .9rem;
  color: var(--teal);
  letter-spacing: .03em;
}

.partner-meta {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: .3rem;
}

/* Type badge */
.partner-badge {
  display: inline-flex;
  align-items: center;
  gap: 4px;
  font-size: .68rem;
  font-weight: 600;
  letter-spacing: .08em;
  text-transform: uppercase;
  color: var(--clay);
  background: color-mix(in srgb, var(--clay) 10%, transparent);
  padding: .2rem .6rem;
  border-radius: 2rem;
  width: fit-content;
}
.partner-badge i {
  font-size: .75rem;
}

.partner-name {
  font-size: 1rem;
  font-weight: 700;
  color: var(--night);
  margin: 0;
  line-height: 1.3;
}

/* Divider */
.card-divider {
  height: 1px;
  background: rgba(59,42,26,.07);
}

.partner-desc {
  font-size: .85rem;
  line-height: 1.65;
  color: var(--muted);
  margin: 0;
}

/* ── How to partner ── */
.how-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 1.5rem;
  margin-top: 3rem;
}
.how-card {
  background: #fff;
  padding: 2rem 1.5rem;
  border-radius: 16px;
  box-shadow: 0 2px 12px rgba(59,42,26,.06);
  text-align: center;
  transition: transform .3s;
}
.how-card:hover { transform: translateY(-6px); }
.how-icon { font-size: 2.5rem; margin-bottom: 1rem; }
.how-card h3 { font-size: 1rem; margin-bottom: .5rem; }
.how-card p  { font-size: .88rem; }

/* ── Testimonial ── */
.testimonial-block {
  max-width: 720px;
  margin: 0 auto;
  text-align: center;
  position: relative;
  padding: 3rem;
  background: var(--sand);
  border-radius: 24px;
}
.quote-mark {
  font-family: var(--font-display);
  font-size: 8rem;
  line-height: 1;
  color: var(--clay);
  opacity: .15;
  position: absolute;
  top: -.5rem; left: 1.5rem;
}
blockquote {
  font-family: var(--font-display);
  font-style: italic;
  font-size: 1.3rem;
  line-height: 1.65;
  color: var(--night);
  position: relative;
  z-index: 1;
}
cite {
  display: block;
  margin-top: 1.5rem;
  font-size: .88rem;
  font-style: normal;
  color: var(--muted);
}

/* ── Responsive ── */
@media (max-width: 1024px) {
  .partners-grid { grid-template-columns: repeat(2, 1fr); }
  .how-grid       { grid-template-columns: repeat(2, 1fr); }
}
@media (max-width: 600px) {
  .partners-grid { grid-template-columns: 1fr; }
  .how-grid       { grid-template-columns: 1fr; }
}
</style>
