---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import donateData from '../data/donate.json';

const { hero, poBox, impacts, otherWays } = donateData;
---

<Base title="Donate to RAPP" description="Support RAPP's mission — your contributions fund HIV/AIDS awareness, SRHR education, and income-generating cooperatives across Rwanda.">
  <Nav />

  <!-- Hero -->
  <div class="page-hero" style={`background-image: url('${hero.image}')`}>
    <div class="hero-overlay"></div>
    <div class="container hero-inner">
      <span class="section-label fade-up">{hero.label}</span>
      <h1 class="fade-up-2">{hero.title}</h1>
      <p class="fade-up-3">{hero.subtitle}</p>
    </div>
  </div>

  <!-- ✅ FIXED: Impact stats strip -->
  <div class="stats-strip">
    <div class="container stats-inner">
      <div class="stat-item">
        <strong>43,200+</strong>
        <span>Lives Reached</span>
      </div>
      <div class="stat-divider"></div>
      <div class="stat-item">
        <strong>2003</strong>
        <span>Founded</span>
      </div>
      <div class="stat-divider"></div>
      <div class="stat-item">
        <strong>100%</strong>
        <span>To Programmes</span>
      </div>
      <div class="stat-divider"></div>
      <div class="stat-item">
        <strong>Rwanda</strong>
        <span>Registered NGO</span>
      </div>
    </div>
  </div>

  <!-- Main donate section -->
  <section class="section" style="padding-top: 4rem;">
    <div class="container donate-grid">

      <!-- Left column -->
      <div class="donate-left">

        <!-- PO Box card -->
        <div class="pobox-card">
          <div class="pobox-tag">How to Donate</div>
          <div class="pobox-top">
            <div class="envelope-circle">✉️</div>
            <div>
              <h2>{poBox.heading}</h2>
              <p class="pobox-sub">{poBox.message}</p>
            </div>
          </div>

          <div class="address-block">
            <div class="address-label">Mailing Address</div>
            <div class="address-lines">
              {poBox.address.split('\n').map((line: string) => (
                <span class="address-line">{line}</span>
              ))}
            </div>
          </div>

          <div class="pobox-note">
            <div class="note-icon-wrap">💛</div>
            <p>Your mailed contribution goes directly to our programmes. Every amount — large or small — makes a real difference to the communities we serve.</p>
          </div>

          <div class="trust-row">
            <div class="trust-badge">
              <span class="trust-icon">✅</span>
              <span>Registered NGO</span>
            </div>
            <div class="trust-sep"></div>
            <div class="trust-badge">
              <span class="trust-icon">📋</span>
              <span>100% to Programmes</span>
            </div>
            <div class="trust-sep"></div>
            <div class="trust-badge">
              <span class="trust-icon">🌍</span>
              <span>Since 2003</span>
            </div>
          </div>
        </div>

        <!-- Other Ways -->
        <div class="other-ways-wrap">
          <div class="ways-header">
            <div class="ways-line"></div>
            <h3>Other Ways to Give</h3>
            <div class="ways-line"></div>
          </div>
          <div class="ways-grid">
            {otherWays.map((w: any) => (
              <div class="way-card">
                <div class="way-icon-wrap">{w.icon}</div>
                <h4>{w.title}</h4>
                <p>{w.desc}</p>
                <a href="/contact" class="way-link">Ask Us How →</a>
              </div>
            ))}
          </div>
        </div>

      </div>

      <!-- Right: Impact sidebar -->
      <aside class="impact-sidebar">

        <div class="impact-header">
          <div class="impact-header-icon">💡</div>
          <h3>Your Gift in Action</h3>
          <p>See how every contribution changes lives across Rwanda</p>
        </div>

        <div class="impact-list">
          {impacts.map((i: any) => (
            <div class="impact-item">
              <div class="impact-icon-wrap">
                <span>{i.icon}</span>
              </div>
              <div class="impact-text">
                <strong class="impact-amount">{i.amount}</strong>
                <p>{i.desc}</p>
              </div>
            </div>
          ))}
        </div>

        <div class="quote-card">
          <div class="quote-mark">"</div>
          <p>RAPP uses theater to educate youth about HIV/AIDS prevention and empowers vulnerable communities to build sustainable livelihoods.</p>
          <div class="quote-author">— RAPP Team, Kigali</div>
        </div>

        <div class="contact-nudge">
          <div class="nudge-text">
            <strong>Questions about donating?</strong>
            <span>Our team responds within 48 hours.</span>
          </div>
          <a href="/contact" class="btn btn-outline nudge-btn">Contact Us</a>
        </div>

      </aside>
    </div>
  </section>

  <!-- ✅ FIXED: Bottom CTA banner -->
  <section class="cta-section">
    <div class="container">
      <div class="cta-inner">
        <!-- Decorative background elements -->
        <div class="cta-bg-rings" aria-hidden="true">
          <div class="ring ring-1"></div>
          <div class="ring ring-2"></div>
          <div class="ring ring-3"></div>
        </div>
        <div class="cta-bg-dots" aria-hidden="true"></div>

        <!-- Content -->
        <div class="cta-content">
          <div class="cta-label-wrap">
            <span class="cta-eyebrow">Together We Can</span>
          </div>
          <h2>Every Contribution<br/>Reaches a Community<br/>That Needs It</h2>
          <p>Mail your contribution to <strong>PO Box 4637, Kigali</strong> — or reach out and we'll help you find the best way to give.</p>
          <div class="cta-actions">
            <a href="/contact" class="cta-btn-primary">
              <span>Get in Touch</span>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </a>
            <a href="/about" class="cta-btn-ghost">Learn About RAPP</a>
          </div>
        </div>

        <!-- Right decorative stat badges -->
        <div class="cta-badges" aria-hidden="true">
          <div class="cta-badge">
            <span class="badge-num">43,200+</span>
            <span class="badge-label">Lives Reached</span>
          </div>
          <div class="cta-badge cta-badge--accent">
            <span class="badge-num">100%</span>
            <span class="badge-label">Goes to Programmes</span>
          </div>
          <div class="cta-badge">
            <span class="badge-num">20+</span>
            <span class="badge-label">Years of Impact</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <Footer />
</Base>

<style>
/* ── Hero ── */
.page-hero {
  position: relative;
  min-height: 55vh;
  display: flex;
  align-items: flex-end;
  background-size: cover;
  background-position: center 40%;
  padding-bottom: 4rem;
}
.hero-overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(to bottom, rgba(13,43,69,.3) 0%, rgba(13,43,69,.75) 100%);
}
.hero-inner {
  position: relative;
  z-index: 1;
  color: #fff;
}
.hero-inner h1 { color: #fff; font-size: clamp(2rem,5vw,3.2rem); margin-top: .5rem; }
.hero-inner p  { color: rgba(255,255,255,.88); font-size: 1.1rem; max-width: 560px; margin-top: .75rem; }

/* ════════════════════════════════════════
   ✅ STATS STRIP — fully redesigned
   ════════════════════════════════════════ */
.stats-strip {
  background: var(--clay, #c8402f);
  padding: 0;
  position: relative;
  overflow: hidden;
}

/* subtle diagonal texture overlay */
.stats-strip::before {
  content: '';
  position: absolute;
  inset: 0;
  background: repeating-linear-gradient(
    -55deg,
    transparent,
    transparent 40px,
    rgba(0,0,0,.04) 40px,
    rgba(0,0,0,.04) 41px
  );
  pointer-events: none;
}

.stats-inner {
  display: flex;
  align-items: stretch;
  justify-content: center;
  position: relative;
  z-index: 1;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: .3rem;
  padding: 2rem 3.5rem;
  position: relative;
  transition: background .2s;
}

.stat-item:hover {
  background: rgba(0,0,0,.08);
}

.stat-item strong {
  font-family: var(--font-display, Georgia, serif);
  font-size: 2.2rem;
  font-weight: 900;
  color: #fff;
  line-height: 1;
  letter-spacing: -.02em;
}

.stat-item span {
  font-size: .72rem;
  color: rgba(255,255,255,.7);
  text-transform: uppercase;
  letter-spacing: .1em;
  font-weight: 600;
}

.stat-divider {
  width: 1px;
  background: rgba(255,255,255,.2);
  align-self: stretch;
  margin: .75rem 0;
  flex-shrink: 0;
}

/* ── Layout ── */
.donate-grid {
  display: grid;
  grid-template-columns: 1.45fr 1fr;
  gap: 3.5rem;
  align-items: start;
}
.donate-left { display: flex; flex-direction: column; gap: 3rem; }

/* ── PO Box Card ── */
.pobox-card {
  background: #fff;
  border-radius: 24px;
  box-shadow: 0 4px 40px rgba(59,42,26,.1);
  border: 1px solid rgba(59,42,26,.07);
  overflow: hidden;
  position: relative;
}
.pobox-tag {
  display: inline-block;
  background: rgba(29,158,117,.12);
  color: var(--teal, #1d9e75);
  font-size: .68rem;
  font-weight: 700;
  letter-spacing: .1em;
  text-transform: uppercase;
  padding: .3rem .9rem;
  border-radius: 2rem;
  margin: 1.75rem 2.25rem 0;
}
.pobox-top {
  display: flex;
  align-items: center;
  gap: 1.25rem;
  padding: 1.25rem 2.25rem 0;
}
.envelope-circle {
  flex-shrink: 0;
  width: 64px; height: 64px;
  border-radius: 50%;
  background: var(--clay, #c8402f);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 1.75rem;
  box-shadow: 0 6px 20px rgba(200,64,47,.25);
}
.pobox-top h2 { font-size: 1.55rem; margin: 0; }
.pobox-sub { color: var(--muted, #7a6a5a); font-size: .9rem; margin-top: .25rem; }

.address-block {
  margin: 1.75rem 2.25rem;
  background: var(--sand, #f5efe6);
  border-radius: 16px;
  padding: 1.5rem 1.75rem;
  border-left: 4px solid var(--clay, #c8402f);
}
.address-label {
  font-size: .65rem;
  font-weight: 800;
  letter-spacing: .14em;
  color: var(--clay, #c8402f);
  text-transform: uppercase;
  margin-bottom: .6rem;
}
.address-lines { display: flex; flex-direction: column; gap: .15rem; }
.address-line {
  font-family: var(--font-display, Georgia, serif);
  font-size: 1.45rem;
  font-weight: 900;
  color: var(--night, #0d2b45);
  line-height: 1.2;
}

.pobox-note {
  display: flex;
  gap: .85rem;
  align-items: flex-start;
  padding: 0 2.25rem 1.75rem;
}
.note-icon-wrap { font-size: 1.3rem; flex-shrink: 0; margin-top: .1rem; }
.pobox-note p { font-size: .88rem; line-height: 1.65; color: var(--muted, #7a6a5a); }

.trust-row {
  display: flex;
  align-items: center;
  background: var(--night, #0d2b45);
  padding: 1.1rem 2.25rem;
  gap: 0;
}
.trust-badge {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: .25rem;
  flex: 1;
  color: rgba(245,239,230,.8);
  font-size: .75rem;
  font-weight: 600;
  text-align: center;
}
.trust-icon { font-size: 1.1rem; }
.trust-sep {
  width: 1px;
  height: 2rem;
  background: rgba(245,239,230,.12);
}

/* ── Other Ways ── */
.ways-header {
  display: flex;
  align-items: center;
  gap: 1rem;
  margin-bottom: 1.25rem;
}
.ways-line { flex: 1; height: 1px; background: rgba(59,42,26,.12); }
.ways-header h3 {
  font-size: .8rem;
  font-weight: 700;
  letter-spacing: .1em;
  text-transform: uppercase;
  color: var(--muted, #7a6a5a);
  white-space: nowrap;
  margin: 0;
}
.ways-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 1rem;
}
.way-card {
  background: #fff;
  border: 1px solid rgba(59,42,26,.09);
  border-radius: 16px;
  padding: 1.4rem;
  display: flex;
  flex-direction: column;
  transition: box-shadow .25s, transform .25s;
}
.way-card:hover {
  box-shadow: 0 6px 24px rgba(59,42,26,.1);
  transform: translateY(-3px);
}
.way-icon-wrap { font-size: 1.6rem; margin-bottom: .65rem; }
.way-card h4 { font-size: .92rem; margin-bottom: .35rem; }
.way-card p  { font-size: .82rem; color: var(--muted, #7a6a5a); flex: 1; line-height: 1.55; }
.way-link {
  display: inline-block;
  margin-top: .85rem;
  font-size: .8rem;
  font-weight: 700;
  color: var(--clay, #c8402f);
  text-decoration: none;
}
.way-link:hover { text-decoration: underline; }

/* ── Impact Sidebar ── */
.impact-sidebar {
  position: sticky;
  top: calc(var(--nav-h, 72px) + 1.5rem);
  display: flex;
  flex-direction: column;
  gap: 1.25rem;
}

.impact-header {
  background: var(--night, #0d2b45);
  border-radius: 20px;
  padding: 1.75rem;
  text-align: center;
}
.impact-header-icon { font-size: 2rem; margin-bottom: .75rem; }
.impact-header h3 { color: #fff; font-size: 1.15rem; margin: 0 0 .35rem; }
.impact-header p  { color: rgba(255,255,255,.6); font-size: .83rem; margin: 0; }

.impact-list {
  background: #fff;
  border-radius: 20px;
  border: 1px solid rgba(59,42,26,.08);
  overflow: hidden;
}
.impact-item {
  display: flex;
  align-items: center;
  gap: 1rem;
  padding: 1rem 1.4rem;
  border-bottom: 1px solid rgba(59,42,26,.06);
  transition: background .15s;
}
.impact-item:last-child { border-bottom: none; }
.impact-item:hover { background: var(--sand, #f5efe6); }
.impact-icon-wrap {
  flex-shrink: 0;
  width: 40px; height: 40px;
  background: var(--sand, #f5efe6);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 1.2rem;
}
.impact-amount {
  display: block;
  font-family: var(--font-display, Georgia, serif);
  font-size: 1.1rem;
  font-weight: 900;
  color: var(--clay, #c8402f);
  margin-bottom: .1rem;
}
.impact-text p { font-size: .81rem; color: var(--muted, #7a6a5a); line-height: 1.45; }

.quote-card {
  background: var(--sand, #f5efe6);
  border-radius: 20px;
  padding: 1.5rem 1.75rem;
}
.quote-mark {
  font-family: Georgia, serif;
  font-size: 3.5rem;
  color: var(--clay, #c8402f);
  line-height: .6;
  opacity: .4;
  margin-bottom: .65rem;
}
.quote-card p { font-size: .87rem; line-height: 1.65; font-style: italic; color: var(--earth, #3b2a1a); }
.quote-author { font-size: .76rem; font-weight: 700; color: var(--clay, #c8402f); margin-top: .8rem; }

.contact-nudge {
  background: #fff;
  border: 1px solid rgba(59,42,26,.09);
  border-radius: 16px;
  padding: 1.25rem 1.5rem;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 1rem;
}
.nudge-text { display: flex; flex-direction: column; gap: .1rem; }
.nudge-text strong { font-size: .88rem; color: var(--earth, #3b2a1a); }
.nudge-text span   { font-size: .78rem; color: var(--muted, #7a6a5a); }
.nudge-btn { font-size: .82rem; padding: .45rem 1.1rem; white-space: nowrap; }

/* ════════════════════════════════════════
   ✅ CTA SECTION — fully redesigned
   ════════════════════════════════════════ */
.cta-section {
  padding: 2rem 0 5rem;
}

.cta-inner {
  position: relative;
  background: var(--night, #0d2b45);
  border-radius: 28px;
  padding: 5rem 4.5rem;
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 3rem;
}

/* Decorative rings */
.cta-bg-rings { position: absolute; inset: 0; pointer-events: none; }
.ring {
  position: absolute;
  border-radius: 50%;
  border: 1px solid rgba(245,239,230,.06);
}
.ring-1 { width: 500px; height: 500px; top: -200px; right: -150px; }
.ring-2 { width: 320px; height: 320px; top: -80px; right: -30px; }
.ring-3 { width: 240px; height: 240px; bottom: -100px; left: -80px; }

/* Dot grid texture */
.cta-bg-dots {
  position: absolute;
  inset: 0;
  pointer-events: none;
  background-image: radial-gradient(rgba(255,255,255,.07) 1px, transparent 1px);
  background-size: 28px 28px;
  mask-image: radial-gradient(ellipse 60% 80% at 50% 50%, black 40%, transparent 100%);
}

/* Left: text content */
.cta-content {
  position: relative;
  z-index: 1;
  flex: 1;
  max-width: 520px;
}

.cta-label-wrap {
  display: flex;
  align-items: center;
  gap: .75rem;
  margin-bottom: 1.25rem;
}
.cta-label-wrap::before {
  content: '';
  display: block;
  width: 32px;
  height: 2px;
  background: var(--gold, #e8a838);
  border-radius: 2px;
}

.cta-eyebrow {
  font-size: .7rem;
  font-weight: 700;
  letter-spacing: .14em;
  text-transform: uppercase;
  color: var(--gold, #e8a838);
}

.cta-content h2 {
  font-family: var(--font-display, Georgia, serif);
  font-size: clamp(1.75rem, 3vw, 2.5rem);
  color: #fff;
  line-height: 1.2;
  margin-bottom: 1.1rem;
  font-weight: 900;
}

.cta-content p {
  color: rgba(245,239,230,.65);
  font-size: .97rem;
  line-height: 1.75;
  margin-bottom: 2.25rem;
}

.cta-content p strong {
  color: rgba(245,239,230,.9);
  font-weight: 700;
}

.cta-actions {
  display: flex;
  align-items: center;
  gap: 1.1rem;
  flex-wrap: wrap;
}

.cta-btn-primary {
  display: inline-flex;
  align-items: center;
  gap: .55rem;
  background: var(--clay, #c8402f);
  color: #fff;
  text-decoration: none;
  font-weight: 700;
  font-size: .95rem;
  padding: .9rem 2rem;
  border-radius: 999px;
  transition: background .2s, transform .2s, box-shadow .2s;
  box-shadow: 0 4px 20px rgba(200,64,47,.4);
}
.cta-btn-primary:hover {
  background: #b5401f;
  transform: translateY(-2px);
  box-shadow: 0 8px 28px rgba(200,64,47,.5);
}
.cta-btn-primary svg {
  transition: transform .2s;
}
.cta-btn-primary:hover svg {
  transform: translateX(3px);
}

.cta-btn-ghost {
  display: inline-flex;
  align-items: center;
  color: rgba(245,239,230,.7);
  text-decoration: none;
  font-size: .9rem;
  font-weight: 600;
  border-bottom: 1px solid rgba(245,239,230,.25);
  padding-bottom: .1rem;
  transition: color .2s, border-color .2s;
}
.cta-btn-ghost:hover {
  color: #fff;
  border-color: rgba(245,239,230,.6);
}

/* Right: floating stat badges */
.cta-badges {
  position: relative;
  z-index: 1;
  flex-shrink: 0;
  display: flex;
  flex-direction: column;
  gap: .85rem;
  width: 200px;
}

.cta-badge {
  background: rgba(245,239,230,.07);
  border: 1px solid rgba(245,239,230,.12);
  border-radius: 16px;
  padding: 1.1rem 1.4rem;
  display: flex;
  flex-direction: column;
  gap: .2rem;
  backdrop-filter: blur(4px);
  transition: background .2s, border-color .2s;
}
.cta-badge:hover {
  background: rgba(245,239,230,.12);
  border-color: rgba(245,239,230,.2);
}
.cta-badge--accent {
  background: rgba(200,64,47,.2);
  border-color: rgba(200,64,47,.4);
}
.cta-badge--accent:hover {
  background: rgba(200,64,47,.28);
}

.badge-num {
  font-family: var(--font-display, Georgia, serif);
  font-size: 1.6rem;
  font-weight: 900;
  color: #fff;
  line-height: 1;
}
.cta-badge--accent .badge-num {
  color: #ffa58c;
}
.badge-label {
  font-size: .68rem;
  font-weight: 600;
  color: rgba(245,239,230,.55);
  text-transform: uppercase;
  letter-spacing: .08em;
}
.cta-badge--accent .badge-label {
  color: rgba(255,165,140,.7);
}

/* ── Responsive ── */
@media (max-width: 1024px) {
  .donate-grid { grid-template-columns: 1fr; }
  .impact-sidebar { position: static; }
  .stat-item { padding: 1.5rem 2rem; }
  .cta-inner {
    flex-direction: column;
    text-align: center;
    padding: 3.5rem 2.5rem;
  }
  .cta-content { max-width: 100%; }
  .cta-label-wrap { justify-content: center; }
  .cta-actions { justify-content: center; }
  .cta-badges {
    width: 100%;
    flex-direction: row;
    justify-content: center;
  }
  .cta-badge { flex: 1; max-width: 160px; align-items: center; text-align: center; }
}
@media (max-width: 600px) {
  .ways-grid { grid-template-columns: 1fr; }
  .pobox-top { flex-direction: column; text-align: center; }
