---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import donateData from '../data/donate.json';

const { hero, poBox, impacts, otherWays } = donateData;
---

<Base title="Donate to RAPP" description="Support RAPP's mission — your contributions fund HIV/AIDS awareness, SRHR education, and income-generating cooperatives across Rwanda.">
  <Nav />

  <!-- Hero -->
  <div class="page-hero" style={`background-image: url('${hero.image}')`}>
    <div class="hero-overlay"></div>
    <div class="container hero-inner">
      <span class="section-label fade-up">{hero.label}</span>
      <h1 class="fade-up-2">{hero.title}</h1>
      <p class="fade-up-3">{hero.subtitle}</p>
    </div>
  </div>

  <!-- How to Donate — main section -->
  <section class="section">
    <div class="container donate-grid">

      <!-- Left: PO Box + other ways -->
      <div class="donate-left">

        <!-- PO Box card — the star -->
        <div class="pobox-card">
          <div class="pobox-top">
            <div class="envelope-wrap">
              <div class="envelope">✉️</div>
            </div>
            <div class="pobox-headline">
              <h2>{poBox.heading}</h2>
              <p class="pobox-sub">{poBox.message}</p>
            </div>
          </div>

          <div class="address-block">
            <div class="address-label">MAILING ADDRESS</div>
            <div class="address-lines">
              {poBox.address.split('\n').map((line: string) => (
                <span class="address-line">{line}</span>
              ))}
            </div>
          </div>

          <div class="pobox-note">
            <span class="note-icon">💛</span>
            <p>Your mailed contribution goes directly to our programmes. Every amount — large or small — makes a real difference to the communities we serve.</p>
          </div>

          <!-- Trust badges -->
          <div class="trust-row">
            <div class="trust-badge">
              <span>✅</span>
              <span>Registered NGO</span>
            </div>
            <div class="trust-badge">
              <span>📋</span>
              <span>100% to Programmes</span>
            </div>
            <div class="trust-badge">
              <span>🌍</span>
              <span>Since 2003</span>
            </div>
          </div>
        </div>

        <!-- Other Ways -->
        <div class="other-ways-wrap">
          <h3 class="ways-title">
            <span class="title-line"></span>
            Other Ways to Give
            <span class="title-line"></span>
          </h3>
          <div class="ways-grid">
            {otherWays.map((w: any) => (
              <div class="way-card">
                <div class="way-icon">{w.icon}</div>
                <h4>{w.title}</h4>
                <p>{w.desc}</p>
                <a href="/contact" class="way-link">Ask Us How →</a>
              </div>
            ))}
          </div>
        </div>
      </div>

      <!-- Right: Impact sidebar -->
      <aside class="impact-sidebar">
        <div class="impact-header">
          <h3>Your Gift in Action</h3>
          <p>See how every contribution changes lives across Rwanda</p>
        </div>
        <div class="impact-list">
          {impacts.map((i: any) => (
            <div class="impact-item">
              <div class="impact-icon-wrap">
                <span class="impact-icon">{i.icon}</span>
              </div>
              <div class="impact-text">
                <strong class="impact-amount">{i.amount}</strong>
                <p>{i.desc}</p>
              </div>
            </div>
          ))}
        </div>

        <!-- Quote -->
        <div class="quote-card">
          <div class="quote-mark">"</div>
          <p>RAPP uses theater to educate youth about HIV/AIDS prevention and empowers vulnerable communities to build sustainable livelihoods.</p>
          <div class="quote-author">— RAPP Team, Kigali</div>
        </div>

        <!-- Contact nudge -->
        <div class="contact-nudge">
          <p>Questions about donating?</p>
          <a href="/contact" class="btn btn-outline nudge-btn">Contact Us</a>
        </div>
      </aside>
    </div>
  </section>

  <!-- Bottom banner -->
  <section class="cta-section">
    <div class="cta-bg"></div>
    <div class="container cta-inner">
      <span class="section-label" style="color:var(--gold)">Together We Can</span>
      <h2 style="color:#fff;max-width:640px;margin:.5rem auto 0;">Every Contribution Reaches a Community That Needs It</h2>
      <p style="color:rgba(245,239,230,.8);max-width:480px;margin:1rem auto 0;">
        Mail your contribution to PO Box 4637, Kigali — or reach out and we'll help you find the best way to give.
      </p>
      <a href="/contact" class="btn btn-primary" style="margin-top:2rem;display:inline-block;">Get in Touch</a>
    </div>
  </section>

  <Footer />
</Base>

<style>
/* ── Hero ── */
.page-hero {
  position: relative;
  min-height: 52vh;
  display: flex;
  align-items: flex-end;
  background-size: cover;
  background-position: center 40%;
  padding-bottom: 4rem;
}
.hero-overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(to bottom, rgba(13,43,69,.35) 0%, rgba(13,43,69,.72) 100%);
}
.hero-inner {
  position: relative;
  z-index: 1;
  color: #fff;
}
.hero-inner h1 { color: #fff; font-size: clamp(2rem, 5vw, 3.2rem); margin-top: .5rem; }
.hero-inner p  { color: rgba(255,255,255,.88); font-size: 1.1rem; max-width: 560px; margin-top: .75rem; }

/* ── Layout ── */
.donate-grid {
  display: grid;
  grid-template-columns: 1.45fr 1fr;
  gap: 3.5rem;
  align-items: start;
}
.donate-left { display: flex; flex-direction: column; gap: 3rem; }

/* ── PO Box Card ── */
.pobox-card {
  background: #fff;
  border-radius: calc(var(--r)*3);
  box-shadow: 0 8px 48px rgba(59,42,26,.1);
  overflow: hidden;
  border: 1px solid rgba(59,42,26,.07);
}
.pobox-top {
  display: flex;
  align-items: center;
  gap: 1.5rem;
  padding: 2.25rem 2.25rem 0;
}
.envelope-wrap {
  flex-shrink: 0;
  width: 72px; height: 72px;
  border-radius: 50%;
  background: linear-gradient(135deg, var(--clay), #e05a3a);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 2rem;
  box-shadow: 0 8px 24px rgba(200,64,47,.3);
}
.pobox-headline h2 {
  font-size: 1.6rem;
  margin: 0;
}
.pobox-sub {
  color: var(--muted);
  font-size: .93rem;
  margin-top: .3rem;
}

.address-block {
  margin: 2rem 2.25rem;
  background: linear-gradient(135deg, var(--sand) 0%, #f0e8d8 100%);
  border-radius: calc(var(--r)*2);
  padding: 1.75rem 2rem;
  border-left: 4px solid var(--clay);
  position: relative;
  overflow: hidden;
}
.address-block::after {
  content: '✉';
  position: absolute;
  right: 1.5rem;
  top: 50%;
  transform: translateY(-50%);
  font-size: 4rem;
  opacity: .07;
}
.address-label {
  font-size: .65rem;
  font-weight: 800;
  letter-spacing: .14em;
  color: var(--clay);
  text-transform: uppercase;
  margin-bottom: .75rem;
}
.address-lines {
  display: flex;
  flex-direction: column;
  gap: .2rem;
}
.address-line {
  font-family: var(--font-display);
  font-size: 1.55rem;
  font-weight: 900;
  color: var(--night);
  line-height: 1.2;
  letter-spacing: .01em;
}

.pobox-note {
  display: flex;
  gap: .9rem;
  align-items: flex-start;
  padding: 0 2.25rem 1.75rem;
}
.note-icon { font-size: 1.4rem; flex-shrink: 0; margin-top: .1rem; }
.pobox-note p { font-size: .9rem; line-height: 1.65; color: var(--muted); }

.trust-row {
  display: flex;
  justify-content: space-around;
  background: var(--night);
  padding: 1.1rem 1.5rem;
}
.trust-badge {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: .3rem;
  color: rgba(245,239,230,.85);
  font-size: .78rem;
  font-weight: 600;
  letter-spacing: .03em;
  text-align: center;
}
.trust-badge span:first-child { font-size: 1.1rem; }

/* ── Other Ways ── */
.ways-title {
  display: flex;
  align-items: center;
  gap: 1rem;
  font-size: 1.15rem;
  color: var(--muted);
  font-weight: 700;
  letter-spacing: .03em;
  text-transform: uppercase;
  font-size: .82rem;
  margin-bottom: 1.25rem;
}
.title-line { flex: 1; height: 1px; background: rgba(59,42,26,.15); }
.ways-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 1rem;
}
.way-card {
  background: #fff;
  border: 1px solid rgba(59,42,26,.09);
  border-radius: calc(var(--r)*2);
  padding: 1.4rem;
  display: flex;
  flex-direction: column;
  transition: box-shadow .2s, transform .2s;
}
.way-card:hover {
  box-shadow: 0 4px 20px rgba(59,42,26,.1);
  transform: translateY(-2px);
}
.way-icon { font-size: 1.6rem; margin-bottom: .6rem; }
.way-card h4 { font-size: .92rem; margin-bottom: .35rem; }
.way-card p  { font-size: .82rem; color: var(--muted); flex: 1; line-height: 1.55; }
.way-link {
  display: inline-block;
  margin-top: .85rem;
  font-size: .8rem;
  font-weight: 700;
  color: var(--clay);
  text-decoration: none;
}
.way-link:hover { text-decoration: underline; }

/* ── Impact Sidebar ── */
.impact-sidebar {
  position: sticky;
  top: calc(var(--nav-h) + 1.5rem);
  display: flex;
  flex-direction: column;
  gap: 1.5rem;
}
.impact-header {
  background: linear-gradient(135deg, var(--night) 0%, #1a3a5c 100%);
  border-radius: calc(var(--r)*2);
  padding: 1.5rem 1.75rem;
  color: #fff;
}
.impact-header h3 { color: #fff; font-size: 1.2rem; margin-bottom: .35rem; }
.impact-header p  { color: rgba(255,255,255,.7); font-size: .85rem; }

.impact-list {
  background: #fff;
  border-radius: calc(var(--r)*2);
  border: 1px solid rgba(59,42,26,.08);
  overflow: hidden;
}
.impact-item {
  display: flex;
  align-items: center;
  gap: 1rem;
  padding: 1rem 1.5rem;
  border-bottom: 1px solid rgba(59,42,26,.07);
  transition: background .15s;
}
.impact-item:last-child { border-bottom: none; }
.impact-item:hover { background: var(--sand); }
.impact-icon-wrap {
  flex-shrink: 0;
  width: 42px; height: 42px;
  background: linear-gradient(135deg, var(--sand), #efe3cf);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 1.3rem;
}
.impact-amount {
  display: block;
  font-family: var(--font-display);
  font-size: 1.15rem;
  font-weight: 900;
  color: var(--clay);
  margin-bottom: .15rem;
}
.impact-text p { font-size: .82rem; color: var(--muted); line-height: 1.45; }

.quote-card {
  background: var(--sand);
  border-radius: calc(var(--r)*2);
  padding: 1.5rem 1.75rem;
  position: relative;
}
.quote-mark {
  font-family: Georgia, serif;
  font-size: 4rem;
  color: var(--clay);
  line-height: .6;
  margin-bottom: .75rem;
  opacity: .5;
}
.quote-card p { font-size: .88rem; line-height: 1.65; font-style: italic; color: var(--earth); }
.quote-author { font-size: .78rem; font-weight: 700; color: var(--clay); margin-top: .85rem; }

.contact-nudge {
  background: #fff;
  border: 1px solid rgba(59,42,26,.1);
  border-radius: calc(var(--r)*2);
  padding: 1.25rem 1.5rem;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 1rem;
}
.contact-nudge p { font-size: .9rem; font-weight: 600; color: var(--earth); }
.nudge-btn { font-size: .82rem; padding: .45rem 1.1rem; white-space: nowrap; }

/* ── Bottom CTA ── */
.cta-section {
  position: relative;
  padding: 6rem 0;
  text-align: center;
  overflow: hidden;
}
.cta-bg {
  position: absolute;
  inset: 0;
  background: linear-gradient(135deg, var(--night) 0%, #1a4a6b 50%, var(--clay) 100%);
}
.cta-inner { position: relative; z-index: 1; }

/* ── Responsive ── */
@media (max-width: 1024px) {
  .donate-grid { grid-template-columns: 1fr; }
  .impact-sidebar { position: static; }
}
@media (max-width: 600px) {
  .ways-grid { grid-template-columns: 1fr; }
  .pobox-top { flex-direction: column; text-align: center; }
  .address-line { font-size: 1.2rem; }
  .contact-nudge { flex-direction: column; text-align: center; }
}
</style>
