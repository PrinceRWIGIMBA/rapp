---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import aboutData from '../data/about.json';

const { hero, story, values, milestones, team } = aboutData;
---

<Base title="About Us" description="Learn about RAPP's history, mission, values, and the team driving peace and progress in Rwanda.">
  <Nav />

  <div class="page-hero" style={`background-image: url('${hero.image}')`}>
    <div class="container">
      <span class="section-label fade-up">{hero.label}</span>
      <h1 class="fade-up-2">{hero.title}</h1>
      <p class="fade-up-3">{hero.subtitle}</p>
    </div>
  </div>

  <!-- Story -->
  <section class="section">
    <div class="container story-layout">
      <div class="story-text">
        <span class="section-label">{story.label}</span>
        <h2>{story.title}</h2>
        <div class="divider"></div>
        {story.paragraphs.map((p: string, i: number) => <p style={i > 0 ? 'margin-top:1rem;' : ''}>{p}</p>)}
      </div>
      <div class="story-img-wrap">
        <img src={story.image} alt="RAPP team meeting" class="story-img" />
      </div>
    </div>
  </section>

  <!-- Values -->
  <section class="section bg-sand">
    <div class="container">
      <div class="section-header" style="text-align:center;">
        <span class="section-label">What Guides Us</span>
        <h2>Our Core Values</h2>
        <div class="divider" style="margin:1rem auto;"></div>
      </div>
      <div class="values-grid">
        {values.map(v => (
          <div class="value-card">
            <div class="value-icon">{v.icon}</div>
            <h3>{v.title}</h3>
            <p>{v.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Timeline -->
  <section class="section">
    <div class="container">
      <div class="section-header">
        <span class="section-label">Our Journey</span>
        <h2>A Decade of Impact</h2>
        <div class="divider"></div>
      </div>
      <div class="timeline">
        {milestones.map((m, i) => (
          <div class={`timeline-item ${i % 2 === 0 ? 'left' : 'right'}`}>
            <div class="timeline-year">{m.year}</div>
            <div class="timeline-dot"></div>
            <div class="timeline-content"><p>{m.event}</p></div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Team Carousel -->
  <section class="section bg-sand">
    <div class="container">
      <div class="section-header" style="text-align:center;">
        <span class="section-label">The People Behind RAPP</span>
        <h2>Our Leadership Team</h2>
        <div class="divider" style="margin:1rem auto;"></div>
        <p class="team-subtitle">Nine dedicated professionals driving peace and progress across Rwanda.</p>
      </div>

      <div class="carousel-wrapper" id="teamCarousel">
        <div class="carousel-track" id="carouselTrack">
          {team.map((m, i) => (
            <div class="team-card" data-index={i}>
              <div class="team-photo-wrap">
                <img src={m.photo} alt={m.name} class="team-photo" loading="lazy" />
              </div>
              <h3 class="team-name">{m.name}</h3>
              <p class="team-role">{m.role}</p>
              <p class="team-bio">{m.bio}</p>

              {(m.phone || m.email) && (
                <div class="team-contact">
                  {m.phone && (
                    <a href={`tel:${m.phone.replace(/\s/g, '')}`} class="team-contact-item">
                      <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 1.18h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.77a16 16 0 0 0 6.29 6.29l.96-.96a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/>
                      </svg>
                      <span>{m.phone}</span>
                    </a>
                  )}
                  {m.email && (
                    <a href={`mailto:${m.email}`} class="team-contact-item">
                      <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <rect width="20" height="16" x="2" y="4" rx="2"/>
                        <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
                      </svg>
                      <span>{m.email}</span>
                    </a>
                  )}
                </div>
              )}
            </div>
          ))}
        </div>

        <button class="carousel-btn prev" id="prevBtn" aria-label="Previous">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
        </button>
        <button class="carousel-btn next" id="nextBtn" aria-label="Next">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
        </button>

        <div class="carousel-dots" id="carouselDots">
          {team.map((_, i) => (
            <button class={`dot ${i === 0 ? 'active' : ''}`} data-dot={i} aria-label={`Go to slide ${i + 1}`}></button>
          ))}
        </div>

        <div class="carousel-progress">
          <div class="carousel-progress-bar" id="progressBar"></div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section">
    <div class="container" style="max-width:620px;margin:0 auto;text-align:center;">
      <span class="section-label">Join the Movement</span>
      <h2>Be Part of Rwanda's Progress</h2>
      <div class="divider" style="margin:1rem auto;"></div>
      <p>Together we can build a Rwanda where every person lives in peace, dignity, and opportunity.</p>
      <div style="display:flex;gap:1rem;justify-content:center;margin-top:2rem;flex-wrap:wrap;">
        <a href="/donate" class="btn btn-primary">Donate Now</a>
        <a href="/contact" class="btn btn-outline">Get in Touch</a>
      </div>
    </div>
  </section>

  <Footer />
</Base>

<style>
/* Story */
.story-layout {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 5rem;
  align-items: center;
}
.story-img {
  width: 100%;
  height: 460px;
  object-fit: cover;
  border-radius: calc(var(--r)*2);
  box-shadow: 0 24px 64px rgba(59,42,26,.18);
}
.story-text h2 { margin-top: .5rem; }

/* Values */
.values-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1.5rem;
}
.value-card {
  background: #fff;
  padding: 2rem 1.5rem;
  border-radius: calc(var(--r)*2);
  box-shadow: 0 2px 12px rgba(59,42,26,.06);
  transition: transform .3s;
}
.value-card:hover { transform: translateY(-5px); }
.value-icon { font-size: 2rem; margin-bottom: .75rem; }
.value-card h3 { font-size: 1rem; margin-bottom: .5rem; }
.value-card p  { font-size: .88rem; }

/* Timeline */
.timeline {
  position: relative;
  max-width: 860px;
  margin: 0 auto;
}
.timeline::before {
  content: '';
  position: absolute;
  left: 50%; top: 0; bottom: 0;
  width: 2px;
  background: rgba(59,42,26,.12);
  transform: translateX(-50%);
}
.timeline-item {
  display: grid;
  grid-template-columns: 1fr 24px 1fr;
  gap: 1.5rem;
  align-items: center;
  margin-bottom: 2.5rem;
  position: relative;
}
.timeline-item.left .timeline-year { text-align: right; order: 1; }
.timeline-item.left .timeline-dot  { order: 2; }
.timeline-item.left .timeline-content { order: 3; }
.timeline-item.right .timeline-year { text-align: left; order: 3; }
.timeline-item.right .timeline-dot  { order: 2; }
.timeline-item.right .timeline-content { order: 1; text-align: right; }
.timeline-year {
  font-family: var(--font-display);
  font-weight: 900;
  font-size: 1.75rem;
  color: var(--clay);
}
.timeline-dot {
  width: 16px; height: 16px;
  border-radius: 50%;
  background: var(--clay);
  box-shadow: 0 0 0 4px rgba(26,107,138,.2);
  justify-self: center;
  flex-shrink: 0;
}
.timeline-content {
  background: #fff;
  padding: 1rem 1.25rem;
  border-radius: var(--r);
  box-shadow: 0 2px 12px rgba(59,42,26,.07);
  font-size: .9rem;
}

/* Team Carousel */
.team-subtitle {
  color: var(--muted);
  font-size: .95rem;
  margin-top: .5rem;
}
.carousel-wrapper {
  position: relative;
  overflow: hidden;
  padding-bottom: 4rem;
}
.carousel-track {
  display: flex;
  gap: 1.5rem;
  transition: transform .55s cubic-bezier(.25,.46,.45,.94);
  will-change: transform;
}
.team-card {
  background: #fff;
  padding: 2rem 1.5rem;
  border-radius: calc(var(--r)*2);
  box-shadow: 0 2px 16px rgba(13,43,69,.08);
  text-align: center;
  flex: 0 0 calc(33.333% - 1rem);
  transition: transform .3s, box-shadow .3s;
}
.team-card:hover {
  transform: translateY(-6px);
  box-shadow: 0 16px 48px rgba(13,43,69,.14);
}
.team-photo-wrap {
  width: 110px; height: 110px;
  border-radius: 50%;
  overflow: hidden;
  margin: 0 auto 1.25rem;
  border: 3px solid var(--sand);
  box-shadow: 0 4px 20px rgba(13,43,69,.18);
}
.team-photo { width: 100%; height: 100%; object-fit: cover; display: block; }
.team-name { font-size: 1.05rem; margin-bottom: .25rem; }
.team-role {
  font-size: .78rem;
  color: var(--clay);
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: .07em;
  margin-bottom: .75rem;
}
.team-bio { font-size: .85rem; line-height: 1.6; margin-bottom: 0; }

/* Contact info */
.team-contact {
  display: flex;
  flex-direction: column;
  gap: .4rem;
  margin-top: 1rem;
  padding-top: 1rem;
  border-top: 1px solid rgba(59,42,26,.09);
}
.team-contact-item {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: .35rem;
  font-size: .77rem;
  color: var(--clay);
  text-decoration: none;
  transition: opacity .2s;
  word-break: break-all;
  line-height: 1.4;
}
.team-contact-item:hover { opacity: .7; text-decoration: underline; }
.team-contact-item svg { flex-shrink: 0; opacity: .65; }

/* Arrows */
.carousel-btn {
  position: absolute;
  top: calc(50% - 2.5rem);
  transform: translateY(-50%);
  width: 44px; height: 44px;
  border-radius: 50%;
  border: 2px solid rgba(26,107,138,.25);
  background: #fff;
  color: var(--clay);
  cursor: pointer;
  display: flex; align-items: center; justify-content: center;
  z-index: 10;
  transition: background .2s, border-color .2s, transform .2s;
  box-shadow: 0 2px 12px rgba(13,43,69,.1);
}
.carousel-btn:hover {
  background: var(--clay);
  color: #fff;
  border-color: var(--clay);
  transform: translateY(-50%) scale(1.08);
}
.carousel-btn:disabled { opacity: .35; cursor: default; pointer-events: none; }
.carousel-btn.prev { left: -1.25rem; }
.carousel-btn.next { right: -1.25rem; }

/* Dots */
.carousel-dots { display: flex; justify-content: center; gap: .5rem; margin-top: 2rem; }
.dot {
  width: 8px; height: 8px;
  border-radius: 999px;
  border: none;
  background: rgba(26,107,138,.25);
  cursor: pointer;
  transition: background .3s, width .3s;
  padding: 0;
}
.dot.active { background: var(--clay); width: 24px; }

/* Progress bar */
.carousel-progress {
  height: 3px;
  background: rgba(26,107,138,.12);
  border-radius: 999px;
  margin-top: 1rem;
  overflow: hidden;
}
.carousel-progress-bar {
  height: 100%;
  background: var(--clay);
  border-radius: 999px;
  transition: width .1s linear;
}

@media (max-width: 1024px) {
  .values-grid { grid-template-columns: repeat(2, 1fr); }
  .team-card   { flex: 0 0 calc(50% - .75rem); }
}
@media (max-width: 900px) {
  .story-layout { grid-template-columns: 1fr; }
  .timeline::before { left: 12px; }
  .timeline-item { grid-template-columns: 24px 1fr; }
  .timeline-item.left  .timeline-year,
  .timeline-item.right .timeline-year { display: none; }
  .timeline-item.left  .timeline-dot  { order: 1; }
  .timeline-item.left  .timeline-content { order: 2; }
  .timeline-item.right .timeline-dot  { order: 1; }
  .timeline-item.right .timeline-content { order: 2; text-align: left; }
  .carousel-btn.prev { left: -.5rem; }
  .carousel-btn.next { right: -.5rem; }
}
@media (max-width: 600px) {
  .values-grid { grid-template-columns: 1fr; }
  .team-card   { flex: 0 0 100%; }
}
</style>

<script>
(function () {
  const track   = document.getElementById('carouselTrack');
  const prevBtn = document.getElementById('prevBtn');
  const nextBtn = document.getElementById('nextBtn');
  const bar     = document.getElementById('progressBar');
  const cards   = track.querySelectorAll('.team-card');
  const total   = cards.length;

  let current  = 0;
  let autoTimer = null;
  const AUTO_MS = 4000;
  const TICK_MS = 50;
  let elapsed   = 0;

  function visibleCount() {
    const w = window.innerWidth;
    if (w <= 600)  return 1;
    if (w <= 1024) return 2;
    return 3;
  }

  function maxIndex() { return total - visibleCount(); }

  function goTo(idx, resetTimer) {
    const vis = visibleCount();
    const max = maxIndex();
    current   = Math.max(0, Math.min(idx, max));

    const cardW = cards[0].offsetWidth;
    track.style.transform = `translateX(-${current * (cardW + 24)}px)`;

    const pages = Math.ceil(total / vis);
    const page  = Math.floor(current / vis);
    document.querySelectorAll('.dot').forEach((d, i) =>
      d.classList.toggle('active', i === page)
    );

    prevBtn.disabled = current === 0;
    nextBtn.disabled = current >= max;

    if (resetTimer) startAuto();
  }

  function tickProgress() {
    elapsed += TICK_MS;
    bar.style.width = (elapsed / AUTO_MS * 100) + '%';
    if (elapsed >= AUTO_MS) {
      goTo(current >= maxIndex() ? 0 : current + 1, false);
      elapsed = 0;
    }
  }

  function startAuto() {
    stopAuto();
    elapsed = 0;
    bar.style.width = '0%';
    autoTimer = setInterval(tickProgress, TICK_MS);
  }

  function stopAuto() { clearInterval(autoTimer); autoTimer = null; }

  prevBtn.addEventListener('click', () => goTo(current - 1, true));
  nextBtn.addEventListener('click', () => goTo(current + 1, true));

  const wrapper = document.getElementById('teamCarousel');
  wrapper.addEventListener('mouseenter', stopAuto);
  wrapper.addEventListener('mouseleave', startAuto);

  let touchStartX = 0;
  track.addEventListener('touchstart', e => { touchStartX = e.touches[0].clientX; stopAuto(); }, { passive: true });
  track.addEventListener('touchend', e => {
    const dx = touchStartX - e.changedTouches[0].clientX;
    if (Math.abs(dx) > 40) goTo(dx > 0 ? current + 1 : current - 1, true);
    else startAuto();
  });

  function rebuildDots() {
    const vis   = visibleCount();
    const pages = Math.ceil(total / vis);
    const el    = document.getElementById('carouselDots');
    el.innerHTML = '';
    for (let i = 0; i < pages; i++) {
      const b = document.createElement('button');
      b.className = 'dot' + (i === 0 ? ' active' : '');
      b.setAttribute('aria-label', `Go to page ${i + 1}`);
      b.addEventListener('click', () => goTo(i * vis, true));
      el.appendChild(b);
    }
  }

  window.addEventListener('resize', () => { rebuildDots(); goTo(current, false); });

  rebuildDots();
  goTo(0, false);
  startAuto();
})();
</script>